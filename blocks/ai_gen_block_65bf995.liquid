{% doc %}
  @prompt
    Images collage

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-collage-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;}

  .ai-image-collage-{{ ai_gen_id }}--layout-grid {
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-masonry {
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    grid-auto-rows: 200px;
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-featured {
    grid-template-columns: 2fr 1fr;grid-template-rows: 1fr 1fr;
  }

  .ai-image-collage-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;border-radius: {{ block.settings.item_border_radius }}px;
    background-color: #f4f4f4;min-height: 200px;
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-featured .ai-image-collage-item-{{ ai_gen_id }}:first-child {
    grid-row: 1 / 3;
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-masonry .ai-image-collage-item-{{ ai_gen_id }}:nth-child(3n+1) {
    grid-row: span 2;
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-masonry .ai-image-collage-item-{{ ai_gen_id }}:nth-child(5n+2) {
    grid-row: span 3;
  }

  .ai-image-collage-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-image-collage-item-{{ ai_gen_id }}:hover img {
    transform: scale({{ block.settings.hover_scale }});
  }

  .ai-image-collage-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;}

  .ai-image-collage-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-image-collage-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-image-collage-item-{{ ai_gen_id }}:hover .ai-image-collage-overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-image-collage-overlay-text-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.overlay_text_size }}px;
    font-weight: 600;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  @media screen and (max-width: 749px) {
    .ai-image-collage-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr) !important;
      gap: {{ block.settings.gap | times: 0.75 }}px;
      padding: {{ block.settings.padding | times: 0.75 }}px;
    }

    .ai-image-collage-{{ ai_gen_id }}--layout-featured {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .ai-image-collage-{{ ai_gen_id }}--layout-featured .ai-image-collage-item-{{ ai_gen_id }}:first-child {
      grid-row: auto;
    }

    .ai-image-collage-{{ ai_gen_id }}--layout-masonry .ai-image-collage-item-{{ ai_gen_id }} {
      grid-row: span 1 !important;
    }

    .ai-image-collage-item-{{ ai_gen_id }} {
      min-height: 150px;
    }

    .ai-image-collage-overlay-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-image-collage-overlay-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-image-collage-{{ ai_gen_id }} ai-image-collage-{{ ai_gen_id }}--layout-{{ block.settings.layout }}"
  {{ block.shopify_attributes }}
>
  {% for i in (1..6) %}
    {% liquid
      assign image_key = 'image_' | append: i
      assign caption_key = 'caption_' | append: i
      assign link_key = 'link_' | append: i
      
      assign image = block.settings[image_key]
      assign caption = block.settings[caption_key]
      assign link = block.settings[link_key]
    %}

    {% if image or forloop.index <= 3 %}
      <div class="ai-image-collage-item-{{ ai_gen_id }}">
        {% if link != blank %}
          <a href="{{ link }}" style="display: block; width: 100%; height: 100%;">
        {% endif %}

        {% if image %}
          <img
            src="{{ image | image_url: width: 800 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {% else %}
          <div class="ai-image-collage-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if caption != blank and block.settings.show_captions %}
          <div class="ai-image-collage-overlay-{{ ai_gen_id }}">
            <div class="ai-image-collage-overlay-text-{{ ai_gen_id }}">
              {{ caption }}
            </div>
          </div>
        {% endif %}

        {% if link != blank %}
          </a>
        {% endif %}
      </div>
    {% endif %}
  {% endfor %}
</div>

