{% doc %}
  @prompt
    Images collage

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-collage-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-grid {
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-masonry {
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    grid-auto-rows: 200px;
  }

  .ai-image-collage-{{ ai_gen_id }}--layout-featured {
    grid-template-columns: 2fr 1fr;grid-template-rows: 1fr 1fr;
  }

  .ai-image-collage-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;border-radius: {{ block.settings.item_border_radius }}px;
    transition: transform 0.3s ease;background-color: #f4f4f4;
  }

  .ai-image-collage-item-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.hover_scale }});
  }

  .ai-image-collage-item-{{ ai_gen_id }}--featured {
    grid-row: 1 / -1;
  }

  .ai-image-collage-item-{{ ai_gen_id }}--tall {
    grid-row: span 2;
  }

  .ai-image-collage-item-{{ ai_gen_id }}--wide {
    grid-column: span 2;
  }

  .ai-image-collage-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-collage-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;}

  .ai-image-collage-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-image-collage-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  {% if block.settings.show_overlay %}
    .ai-image-collage-overlay-{{ ai_gen_id }} {
      opacity: 1;
    }
  {% endif %}

  .ai-image-collage-item-{{ ai_gen_id }}:hover .ai-image-collage-overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-image-collage-text-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: 600;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  @media screen and (max-width: 749px) {
    .ai-image-collage-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr) !important;
      gap: {{ block.settings.gap | times: 0.5 }}px;padding: {{ block.settings.padding | times: 0.5 }}px;
    }

    .ai-image-collage-item-{{ ai_gen_id }}--featured,
    .ai-image-collage-item-{{ ai_gen_id }}--tall,
    .ai-image-collage-item-{{ ai_gen_id }}--wide {
      grid-row: auto;
      grid-column: auto;
    }

    .ai-image-collage-overlay-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-image-collage-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}<div 
  class="ai-image-collage-{{ ai_gen_id }} ai-image-collage-{{ ai_gen_id }}--layout-{{ block.settings.layout }}"
  {{ block.shopify_attributes }}
>
  {% for i in (1..6) %}
    {% liquid
      assign image_key = 'image_' | append: i
      assign text_key = 'text_' | append: i
      assign link_key = 'link_' | append: i
      assign size_key = 'size_' | append: i
      
      assign image = block.settings[image_key]
      assign text = block.settings[text_key]
      assign link = block.settings[link_key]
      assign size = block.settings[size_key]
    %}

    {% if image != blank %}
      {% assign item_class = 'ai-image-collage-item-' | append: ai_gen_id %}
      {% if block.settings.layout == 'featured' and i == 1 %}
        {% assign item_class = item_class | append: ' ai-image-collage-item-' | append: ai_gen_id | append: '--featured' %}
      {% elsif block.settings.layout == 'masonry' %}
        {% if size == 'tall' %}
          {% assign item_class = item_class | append: ' ai-image-collage-item-' | append: ai_gen_id | append: '--tall' %}
        {% elsif size == 'wide' %}
          {% assign item_class = item_class | append: ' ai-image-collage-item-' | append: ai_gen_id | append: '--wide' %}
        {% endif %}
      {% endif %}

      <div class="{{ item_class }}">
        {% if link != blank %}
          <a href="{{ link }}">
        {% endif %}
        <img
          src="{{ image | image_url: width: 800 }}"
          alt="{{ image.alt | escape }}"
          class="ai-image-collage-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ image.width }}"
          height="{{ image.height }}"
        >

        {% if text != blank %}
          <div class="ai-image-collage-overlay-{{ ai_gen_id }}">
            <div class="ai-image-collage-text-{{ ai_gen_id }}">{{ text }}</div>
          </div>
        {% endif %}

        {% if link != blank %}
          </a>
        {% endif %}
      </div>
    {% else %}
      <div class="ai-image-collage-item-{{ ai_gen_id }}">
        <div class="ai-image-collage-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

